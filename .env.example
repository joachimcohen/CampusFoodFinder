# Supabase project settings — Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER prefix with NEXT_PUBLIC_, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Any long random string — signs the vendor PIN session cookie (JWT).
# Generate one with: openssl rand -base64 32
VENDOR_SESSION_SECRET=

# Any long random string — signs the admin "trusted device" cookie (JWT).
# Use a different value than VENDOR_SESSION_SECRET. Generate with: openssl rand -base64 32
ADMIN_DEVICE_SECRET=
